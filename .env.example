# Copy to .env and fill in real values. Do not commit .env.

BOT_TOKEN=your_telegram_bot_token_here
# JSON array of Telegram user IDs (optional for this template)
ADMIN_IDS=[]
# Chat ID for incoming form summaries (group/channel; bot must be a member)
ADMIN_CHAT_ID=-1000000000000
# FSM storage (docker compose uses redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0
